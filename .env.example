# Required: your Google Gemini API key
GEMINI_API_KEY=AIzaSy...

# Required: shared secret — OpenClaw sends this as ?key= param
# Must match the apiKey value in openclaw.json on the VPS
# Use any strong random string, e.g.: openssl rand -hex 32
PROXY_SECRET=your-strong-secret-here

# Bob Mini App auth
BOB_UI_BOT_TOKEN=123456:telegram-bot-token
BOB_UI_ALLOWED_USER_IDS=156025744
BOB_UI_SESSION_SECRET=replace-with-random-secret
BOB_UI_SESSION_TTL_SECONDS=900

# Bob Mini App snapshot bridge
# BOB_UI_SNAPSHOT_SOURCE=demo|file|local|url
BOB_UI_SNAPSHOT_SOURCE=demo
BOB_UI_SNAPSHOT_PATH=/path/to/bob-snapshot.json
# If you publish the Bob bridge root directly, use /snapshot and /actions.
# Example: https://openclaw-vps.taild51c07.ts.net/snapshot
BOB_UI_SNAPSHOT_URL=https://example.com/snapshot
BOB_UI_SNAPSHOT_BEARER_TOKEN=replace-with-snapshot-token
BOB_UI_LOCAL_HEALTH_URL=http://127.0.0.1:18789/healthz
BOB_UI_LOCAL_MODELS_PATH=/home/devops/.openclaw/agents/main/agent/models.json
BOB_UI_LOCAL_OPENCLAW_CONFIG_PATH=/home/devops/.openclaw/openclaw.json
BOB_UI_LOCAL_CRON_PATH=/home/devops/.openclaw/cron/jobs.json
BOB_UI_LOCAL_CONTAINER_NAME=openclaw-openclaw-gateway-1

# Bob Mini App action bridge
BOB_UI_ACTION_BASE_URL=https://example.com/actions
BOB_UI_ACTION_BEARER_TOKEN=replace-with-action-token
BOB_UI_ACTION_IDS=run-model-diagnostics

# Bob bridge inside the OpenClaw gateway
BOB_BRIDGE_BEARER_TOKEN=replace-with-strong-bridge-token
BOB_BRIDGE_ACTION_IDS=run-model-diagnostics
